# Shopify Store Configuration
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token_here

# Inventory Settings
LEAD_TIME_DAYS=7
SAFETY_STOCK=10
MIN_ORDER_QTY=5

# Server
PORT=3000
NODE_ENV=production

# Optional: Send alerts (not implemented yet, for future)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/...
# EMAIL_ALERTS=admin@store.com
